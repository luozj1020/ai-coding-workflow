{
  "schema_version": 1,
  "id": "example-fix-typo-001",
  "mode": "builder",
  "goal": "Fix a typo in the project README.",
  "profiles": ["base", "bugfix"],
  "scope": {
    "write_paths": ["README.md"],
    "read_paths": []
  },
  "acceptance": [
    {
      "id": "typo-fixed",
      "description": "The typo 'teh' is corrected to 'the' in README.md line 42."
    },
    {
      "id": "no-other-changes",
      "description": "No other lines in README.md are modified."
    }
  ],
  "risk": {
    "public_api": "no",
    "data_model": "no",
    "security": "no",
    "migration": "no",
    "permission": "no",
    "concurrency": "no",
    "cross_module": "no",
    "production_impact": "no"
  },
  "handoff": {
    "must_do": [
      "Fix the typo",
      "Show before/after diff"
    ],
    "must_not_do": [
      "Change formatting or structure",
      "Rewrite surrounding sentences"
    ],
    "may_decide": [],
    "must_report": [
      "Exact line changed"
    ],
    "stop_condition": [
      "Typo not found at specified location"
    ]
  },
  "validation": [
    {
      "id": "compile-check",
      "command": ["python", "-m", "py_compile", "README.md"],
      "description": "Verify README is still valid (placeholder — real check would be linter)"
    }
  ],
  "stop_conditions": [
    "typo_not_found",
    "scope_boundary_crossed"
  ],
  "extensions": {}
}
