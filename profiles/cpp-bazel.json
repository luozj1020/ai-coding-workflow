{
  "name": "cpp-bazel",
  "profile_version": 1,
  "description": "C++ repositories built with Bazel",
  "extensions": {
    "context_order": ["clangd", "locator", "bazel-targets", "bounded-codegraph", "targeted-read"],
    "validation": {
      "required_fingerprint": ["git_sha", "bazel", "java", "compiler", "python"],
      "allow_remote_required": true
    }
  }
}
