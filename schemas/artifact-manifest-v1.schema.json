{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-coding-workflow/schemas/artifact-manifest-v1.schema.json",
  "title": "Artifact Manifest v1",
  "description": "Integrity manifest for run artifacts. Version 1 — normative.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "entries"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1,
      "description": "Must be exactly 1 for this schema version."
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Run directory identifier."
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})?$",
      "description": "UTC timestamp when manifest was generated."
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "size",
          "sha256",
          "content_type",
          "producer",
          "phase",
          "required"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Run-relative path to the artifact."
          },
          "size": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes."
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "SHA-256 hex digest of the file content."
          },
          "content_type": {
            "type": "string",
            "minLength": 1,
            "description": "MIME type or descriptive type (e.g. application/json, text/markdown, application/octet-stream)."
          },
          "producer": {
            "type": "string",
            "minLength": 1,
            "description": "Component that produced this artifact (e.g. dispatch, reviewer, checker)."
          },
          "phase": {
            "type": "string",
            "enum": ["setup", "dispatch", "review", "decision", "finalization"],
            "description": "Workflow phase when artifact was produced."
          },
          "required": {
            "type": "boolean",
            "description": "Whether this artifact is required for the run to be considered complete."
          }
        }
      },
      "description": "Manifest entries, one per artifact file."
    }
  }
}
