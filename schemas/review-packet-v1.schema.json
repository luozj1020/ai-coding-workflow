{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-coding-workflow/schemas/review-packet-v1.schema.json",
  "title": "Review Packet v1",
  "description": "Bounded review packet that replaces full evidence concatenation. Version 1 — normative.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "task_summary",
    "active_contracts",
    "acceptance_matrix",
    "changed_files",
    "diff_hunks",
    "checker_summary",
    "failures",
    "artifact_manifest",
    "omitted_evidence",
    "prompt_bytes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1,
      "description": "Must be exactly 1 for this schema version."
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})?$",
      "description": "UTC timestamp when packet was generated."
    },
    "task_summary": {
      "type": "string",
      "description": "Concise task card summary and goal."
    },
    "active_contracts": {
      "type": "string",
      "description": "Active handoff contract, decision gates, and constraints."
    },
    "acceptance_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["satisfied", "failed", "partial", "not-evaluated"]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "Acceptance criteria with current evaluation status."
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["added", "modified", "deleted", "renamed"] }
        }
      },
      "description": "Files changed in this run."
    },
    "diff_hunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "hunk"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "hunk": { "type": "string" }
        }
      },
      "description": "Bounded diff hunks. Truncated if exceeding max_diff_hunks."
    },
    "checker_summary": {
      "type": "string",
      "description": "Checker/validation results summary."
    },
    "failures": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of failure descriptions."
    },
    "artifact_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "size", "content_type", "producer", "required"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "size": { "type": "integer", "minimum": 0 },
          "content_type": { "type": "string" },
          "producer": { "type": "string" },
          "required": { "type": "boolean" }
        }
      },
      "description": "Artifact manifest summary (paths, sizes, types — no hashes)."
    },
    "omitted_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Evidence that was omitted from the packet with the reason (e.g. binary, too large, secrets)."
    },
    "prompt_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Total byte size of the rendered review prompt."
    }
  }
}
