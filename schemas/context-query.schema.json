{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-coding-workflow.local/schemas/context-query.schema.json",
  "title": "Pull Context Query v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["state_id", "requester", "query"],
  "properties": {
    "state_id": {"$ref": "#/$defs/hash"},
    "requester": {"type": "string", "minLength": 1, "maxLength": 256},
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "symbols", "include", "max_bytes"],
      "properties": {
        "intent": {"type": "string", "minLength": 1, "maxLength": 256},
        "symbols": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 512}
        },
        "include": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": ["definition", "callers", "callees", "tests", "build-rules"]
          }
        },
        "max_bytes": {"type": "integer", "minimum": 1, "maximum": 1048576},
        "max_objects": {"type": "integer", "minimum": 1, "maximum": 256},
        "role": {"enum": ["planner", "builder", "checker", "reviewer"]},
        "paths": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 1024}
        }
      }
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
